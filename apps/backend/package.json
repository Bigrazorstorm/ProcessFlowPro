{
  "name": "@processflowpro/backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "postbuild": "node -e \"require('fs').copyFileSync('src/startup.mjs', 'dist/startup.mjs')\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "dev": "nest start --watch",
    "start:prod": "node dist/startup.mjs",
    "start:prod:seed": "SEED_DEMO_DATA=true node dist/startup.mjs",
    "setup": "pnpm run db:migration:run && pnpm run seed:demo",
    "setup:quick": "pnpm run db:migration:run && pnpm run seed:user",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "db:migration:generate": "typeorm migration:generate",
    "db:migration:run": "typeorm migration:run",
    "db:migration:revert": "typeorm migration:revert",
    "seed:demo": "ts-node src/database/seeders/demo.seeder.ts",
    "seed:user": "ts-node src/database/seeders/simple-user.seeder.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.350.0",
    "@nestjs/bull": "^10.0.0",
    "@nestjs/common": "^10.2.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.2.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.2.0",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/typeorm": "^9.0.0",
    "@nestjs/websockets": "^11.1.14",
    "bcrypt": "^6.0.0",
    "bull": "^4.11.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "date-fns": "^2.30.0",
    "date-holidays": "^3.26.0",
    "dotenv": "^16.3.1",
    "nest-winston": "^1.9.4",
    "nodemailer": "^6.9.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.10.0",
    "redis": "^4.6.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.16",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "winston-logstash": "^2.0.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.1.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.4.0",
    "@types/nodemailer": "^6.4.8",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.6.0",
    "jest-mock-extended": "^3.0.4",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.1.0"
  }
}
