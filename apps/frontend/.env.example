# API URL - defaults to /api (proxied by Vite in dev, served from same origin in prod)
# Only set this when you want the browser to make direct requests to the API (bypasses Vite proxy)
# VITE_API_URL=http://localhost:3000/api

# Backend URL - used by the Vite dev server proxy to forward /api requests internally
# Only needed when running in Docker with a separate backend container
# BACKEND_URL=http://backend:3000
